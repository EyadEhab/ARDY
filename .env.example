# EgyptAgri-Pulse Wizard V2.0 - Environment Configuration

# ============================================================================
# WEATHER API CONFIGURATION
# ============================================================================

# OpenWeather API Key (optional - uses demo data if not set)
OPENWEATHER_API_KEY=your_api_key_here

# ============================================================================
# BACKEND CONFIGURATION
# ============================================================================

# Flask environment
FLASK_ENV=production

# Flask app
FLASK_APP=backend.py

# Backend port
BACKEND_PORT=5000

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

# Streamlit server port
STREAMLIT_SERVER_PORT=8501

# Streamlit server address
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# Streamlit headless mode
STREAMLIT_SERVER_HEADLESS=true

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ============================================================================
# NOTES
# ============================================================================

# 1. Copy this file to .env in the project root
# 2. Update values as needed
# 3. Do NOT commit .env to version control
# 4. Use docker-compose up to load these variables
